# =============================================================================
# PLANLUX PRODUKCJA PLANDEK — .gitignore
# Stack: Next.js (App Router) + TypeScript + Tailwind + Electron (desktop shell)
# =============================================================================

# --- dependencies ---
node_modules/

# --- Next.js build output / cache ---
.next/
out/

# --- Electron / desktop build artifacts (common) ---
dist/
build/
release/
releases/
app/dist/
app/build/

# --- logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- environment / secrets ---
.env
.env.*
!.env.example
!.env.local.example

# --- OS / editor junk ---
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

.idea/
.vscode/
*.swp
*.swo

# --- test / coverage ---
coverage/

# --- misc caches ---
.turbo/
.cache/
.parcel-cache/


